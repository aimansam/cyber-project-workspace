# Secrets and local environment
.env
.env.*
*.key
*.pem
*.p12
*.pfx
secrets/

# Large or sensitive evidence artifacts
evidence/**/*.pcap
evidence/**/*.pcapng
evidence/**/*.har
evidence/**/*.zip
evidence/**/*.7z
evidence/**/*.tar
evidence/**/*.gz

# Project repositories live inside the workspace but are not tracked by this repo
red-team/*
!red-team/README.md
blue-team/*
!blue-team/README.md

# Project-specific evidence and reports belong in each project repo
evidence/red-team/*
evidence/blue-team/*
reports/*.md
!reports/README.md

# Python/cache/editor noise
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/
.DS_Store
